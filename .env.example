WEBFORTI_ENV=local
WEBFORTI_PIPELINE_MODE=local
WEBFORTI_PERSISTENCE_BACKEND=memory
WEBFORTI_QUEUE_BACKEND=inline
WEBFORTI_API_KEY=
WEBFORTI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
WEBFORTI_MODEL_PROVIDER=openrouter
WEBFORTI_MODEL_NAME=qwen/qwen3.6-35b-a3b:nitro
WEBFORTI_VERIFICATION_MODE=mock
WEBFORTI_VERIFICATION_TIMEOUT_SECONDS=60

OPENAI_COMPATIBLE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_TITLE=WebForti

MONGO_URI=mongodb://mongo:27017
MONGO_DATABASE=webforti
MONGO_VECTOR_INDEX=knowledge_vector_index
WEBFORTI_EMBEDDING_PROVIDER=sentence_transformers
WEBFORTI_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
WEBFORTI_EMBEDDING_DIMENSIONS=384
POSTGRES_DSN=postgresql://webforti:webforti@postgres:5432/webforti
REDIS_URL=redis://redis:6379/0

GATEWAY_URL=http://gateway:8000
INGESTION_URL=http://data_collector:8001
RAG_URL=http://rag_service:8002
LLM_CORE_URL=http://llm_core:8003
AGENTS_URL=http://agents:8004
ORCHESTRATOR_URL=http://orchestrator:8005

SANDBOX_ALLOW_EGRESS=false
